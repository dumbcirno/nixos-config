#!/usr/bin/env bash
set -euo pipefail

_arg="${1:-}"
if [[ "${_arg}" == "--force" ]]; then
  :
elif [[ -n "${_arg}" ]]; then
  # ignore unknown args to keep module resilient
  :
fi

minute="$(date +%Y%m%d%H%M)"
seed="${minute}${RANDOM}"

pick() {
  local n="$1"
  # bash arithmetic on large seeds can overflow; keep it small
  local s="${seed: -6}"
  echo $(( (10#${s} + RANDOM) % n ))
}

# Clamp an index into an array length (fall back to last element).
clamp_idx() {
  local idx="$1"
  local len="$2"
  if (( len <= 0 )); then
    echo 0
  elif (( idx < len )); then
    echo "$idx"
  else
    echo $((len - 1))
  fi
}

# Keep these short to fit on bar; put longer stuff into tooltip.
icons=( "" "✦" "❖" "☯" "☄" )

texts=(
  "✦ danmaku mood: ON"
  "🧪 9⑨ IQ — perfect!"
  "☕ tea time, yukkuri"
  "🪽 contract? read the fine print"
  "🌀 reality check (magical)"
  "🍉 azumanga energy: 100%"
  "🐧 osaka moment…"
  "🔮 fate is a configuration"
  "🌙 night patrol"
  "🧿 keep calm and graze"
  "котлеты в бургер не вкусны"
  "фильм земляне 2005 года смотреть всем"
  "купи мою маму, я ее продаю"
  "🌸 megalomania"
)

tooltips=(
  "Touhou vibes: danmaku, shrine, incident solving."
  "Touhou: Cirno reference (9⑨)."
  "Touhou-ish: take it yukkuri."
  "Madoka: beware of “too good” offers."
  "Madoka: magical ≠ easy."
  "Azumanga: chaos but cozy."
  "Azumanga: Osaka brain lag."
  "NixOS: fate is declarative."
  "Night mode module."
  "Gensokyo-style calm."
)

classes=( "touhou" "touhou" "touhou" "madoka" "madoka" "azumanga" "azumanga" "meta" "meta" "touhou" )

i_icon="$(pick "${#icons[@]}")"
i_text="$(pick "${#texts[@]}")"

icon="${icons[$i_icon]}"
text="${texts[$i_text]}"

i_tip="$(clamp_idx "$i_text" "${#tooltips[@]}")"
i_cls="$(clamp_idx "$i_text" "${#classes[@]}")"
tooltip="${tooltips[$i_tip]}"
class="${classes[$i_cls]}"

# Minimal JSON escaping for our limited strings.
escape_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/ }"
  printf '%s' "$s"
}

printf '{'
printf '"text":"%s %s",' "$(escape_json "$icon")" "$(escape_json "$text")"
printf '"tooltip":"%s",' "$(escape_json "$tooltip")"
printf '"class":"%s"' "$(escape_json "$class")"
printf '}\n'

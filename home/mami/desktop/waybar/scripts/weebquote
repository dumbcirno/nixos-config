#!/usr/bin/env bash
set -euo pipefail

_arg="${1:-}"
if [[ "${_arg}" == "--force" ]]; then
  :
elif [[ -n "${_arg}" ]]; then
  :
fi

minute="$(date +%Y%m%d%H%M)"
seed="${minute}${RANDOM}"

pick() {
  local n="$1"
  local s="${seed: -6}"
  echo $(( (10#${s} + RANDOM) % n ))
}

icons=( "" "✦" "❖" "☯" "☄" )

entries=(
  $'touhou\t✦ danmaku mood: ON\tTouhou vibes: danmaku, shrine, incident solving.'
  $'touhou\t🧪 9⑨ IQ\tTouhou: Cirno reference (9⑨).'
  $'touhou\t☕ tea time, yukkuri\tTouhou-ish: take it yukkuri.'
  $'madoka\t🌀 reality check (magical)\tMadoka: magical ≠ easy.'
  $'azumanga\t🐧 osaka moment…\tAzumanga: Osaka brain lag.'
  $'meta\t🔮 fate is a configuration\tNixOS: fate is declarative.'

  $'meta\tкотлеты в бургер не вкусны'
  $'meta\tфильм земляне 2005 года смотреть всем'
  $'meta\tкупи мою маму, я ее продаю'
  $'meta\t🌸 megalomania'
)

i_icon="$(pick "${#icons[@]}")"
i_entry="$(pick "${#entries[@]}")"

icon="${icons[$i_icon]}"
entry="${entries[$i_entry]}"
IFS=$'\t' read -r class text tooltip <<<"$entry"
tooltip="${tooltip:-$text}"
class="${class:-meta}"

escape_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/ }"
  printf '%s' "$s"
}

printf '{'
printf '"text":"%s %s",' "$(escape_json "$icon")" "$(escape_json "$text")"
printf '"tooltip":"%s",' "$(escape_json "$tooltip")"
printf '"class":"%s"' "$(escape_json "$class")"
printf '}\n'
